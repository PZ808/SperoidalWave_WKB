Cell[CellGroupData[{
Cell["The Potential", "Section",
 CellChangeTimes->{{3.982408383492688*^9, 
  3.982408387854416*^9}},ExpressionUUID->"45e67991-644a-4098-8648-\
ea2e4fe9bf35"],

Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{"Following", " ", "the", " ", "notes", " ", "of", " ", 
   RowBox[{"Dr", ".", " ", "P", ".", " ", "Zimmerman"}], " ", "the", " ", 
   "Schrodinger", " ", 
   RowBox[{"equation", "/", "liouville"}], " ", "normal", " ", "form", " ", 
   "of", " ", "the", " ", "spin", " ", "spheroidal", " ", "equation", " ", 
   "defined", " ", "by", " ", "the", " ", "potential"}], " ", "*)"}]], "Input",\

 CellChangeTimes->{{3.981976945176793*^9, 3.9819770069788237`*^9}, {
   3.982138911096641*^9, 3.9821389190134983`*^9}, {3.98213897484914*^9, 
   3.982138980459118*^9}, 
   3.9824051825392113`*^9},ExpressionUUID->"1430637b-305a-4091-9b58-\
510a957ae400"],

Cell[BoxData[
 RowBox[{
  RowBox[{"V", "[", "x_", "]"}], ":=", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"Cos", "[", "x", "]"}], "2"], "+", 
   FractionBox[
    RowBox[{"\[Mu]0", "+", 
     RowBox[{"\[Mu]1", " ", 
      RowBox[{"Sin", "[", "x", "]"}]}]}], 
    SuperscriptBox[
     RowBox[{"Cos", "[", "x", "]"}], "2"]], "+", 
   RowBox[{"I", " ", 
    SqrtBox["2"], "\[HBar]", " ", "s", " ", 
    RowBox[{"Sin", "[", "x", "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.98197701606599*^9, 3.981977066654334*^9}},
 CellLabel->
  "In[401]:=",ExpressionUUID->"502ff7bd-2a61-4102-8268-e97fdc84a515"],

Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{"Q", ":", " ", 
   RowBox[{
   "where", " ", "are", " ", "the", " ", "harmonic", " ", "minima", " ", "of",
     " ", "the", " ", "classical", " ", "part", " ", "of", " ", "the", " ", 
    RowBox[{"potential", "?"}]}]}], " ", "*)"}]], "Input",
 CellChangeTimes->{{3.9819771538300457`*^9, 3.981977202238697*^9}, {
  3.982139024957613*^9, 
  3.982139057461097*^9}},ExpressionUUID->"ba6bd291-3c5d-43cd-a374-\
343f99ba3267"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"Cos", "[", "x", "]"}], "2"], "+", 
     FractionBox[
      RowBox[{"\[Mu]0", "+", 
       RowBox[{"\[Mu]1", " ", 
        RowBox[{"Sin", "[", "x", "]"}]}]}], 
      SuperscriptBox[
       RowBox[{"Cos", "[", "x", "]"}], "2"]]}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Mu]0", "->", 
       RowBox[{"1", "/", "2"}]}], ",", 
      RowBox[{"\[Mu]1", "->", 
       RowBox[{"1", "/", "3"}]}]}], "}"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}]}], "]"}]], "Input",
