Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "defines", " ", "richardson", " ", "acceleration", " ", "of", " ", "the", 
    " ", "sequence", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"f", "[", "1", "]"}], ",", 
      RowBox[{"f", "[", "2", "]"}], ",", 
      RowBox[{"f", "[", "3", "]"}], ",", "..."}], "}"}], " ", "of", " ", 
    "order", " ", "O", " ", "evaluated", " ", "at", " ", "the", " ", "nth", 
    " ", "element", " ", "of", " ", 
    RowBox[{
     SubscriptBox["R", "O"], "[", "f", "]"}], 
    RowBox[{"(", "n", ")"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Rich", "[", 
     RowBox[{"f_", ",", "O_", ",", "n_"}], "]"}], ":=", 
    RowBox[{"Sum", "[", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"f", "[", 
         RowBox[{"n", "+", "k"}], "]"}], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"n", "+", "k"}], ")"}], "O"], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], 
         RowBox[{"k", "+", "O"}]]}], 
       RowBox[{
        RowBox[{"k", "!"}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"O", "-", "k"}], ")"}], "!"}]}]], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "0", ",", "O"}], "}"}]}], "]"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "calculates", " ", "tunneling", " ", "action", " ", "from", " ", "ratio", 
     " ", "of", " ", "successive", " ", "terms", " ", "of", " ", "the", " ", 
     "perturbative", " ", 
     RowBox[{"series", ".", " ", "Uses"}], " ", "richardson", " ", "of", " ", 
     "order", " ", "O"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Action", "[", 
     RowBox[{"Edata_", ",", "O_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "sc", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"sc", "[", "t_", "]"}], ":=", 
        FractionBox[
         RowBox[{"t", " ", 
          RowBox[{"Edata", "[", 
           RowBox[{"[", 
            RowBox[{"t", "-", "1"}], "]"}], "]"}]}], 
         RowBox[{" ", 
          RowBox[{"Edata", "[", 
           RowBox[{"[", "t", "]"}], "]"}]}]]}], ";", "\[IndentingNewLine]", 
       RowBox[{"N", "[", 
        RowBox[{
         RowBox[{"Rich", "[", 
          RowBox[{"sc", ",", "O", ",", 
           RowBox[{
            RowBox[{"Length", "[", "Edata", "]"}], "-", "O"}]}], "]"}], ",", 
         "200"}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}]}]}]], "Input",
