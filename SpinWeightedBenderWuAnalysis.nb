 RowBox[{
  RowBox[{"Etest", "=", 
   RowBox[{"RSPT", "[", 
    RowBox[{
     RowBox[{"1", "/", "4"}], ",", 
     RowBox[{
      RowBox[{"-", "1"}], "/", "8"}], ",", 
     FractionBox["I", "100"], ",", "2", ",", "40"}], "]"}]}], ";"}]], "Input",\

 CellChangeTimes->{{3.9821468997023373`*^9, 3.982146921212102*^9}, {
