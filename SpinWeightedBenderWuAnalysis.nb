Cell[CellGroupData[{

Cell["Raleigh-Schrodinger Perturbation theory with Bender Wu", "Section",
 CellChangeTimes->{{3.982139212181252*^9, 3.982139237443244*^9}, 
   3.982144401291871*^9, 3.982146743423338*^9, {3.98525770184636*^9, 
   3.985257736217266*^9}, {3.985257771862995*^9, 3.985257773771462*^9}, 
   3.9853270517203283`*^9},ExpressionUUID->"8ba82333-b9e2-4600-bf54-\
406eae22e09e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Apply", " ", "Bender", " ", "Wu", " ", "mathematical", " ", "package", 
    " ", "to", " ", "generate", " ", 
    RowBox[{"`high", "'"}], " ", "orders", " ", "of", " ", "perturbation", 
    " ", "expansion", " ", "for", " ", "energy", " ", "levels"}], " ", "*)"}],
   "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Inputs", ":"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"\[Mu]0", ",", "\[Mu]1", ",", 
    RowBox[{
    "s", " ", "are", " ", "the", " ", "parameters", " ", "of", " ", "the", 
     " ", "potential"}]}], "  ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"l", " ", "is", " ", "the", " ", "level", " ", "number"}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"M", " ", "is", " ", "the", " ", "order", " ", "of", " ", "PT"}], 
   "  ", "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Outputs", ":"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"list", " ", "of", " ", "form", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x0", ",", 
        RowBox[{"{", 
         RowBox[{"E01", ",", "E02", ",", "...", ",", "E0M"}], "}"}]}], " ", 
       "}"}], ",", "...", ",", 
      RowBox[{"{", 
       RowBox[{"xm", ",", 
        RowBox[{"{", 
         RowBox[{"Em1", ",", "Em2", ",", "...", ",", "EmM"}], "}"}]}], 
       "}"}]}], "}"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"That", " ", "is"}], ",", " ", 
    RowBox[{
    "applies", " ", "BenderWu", " ", "at", " ", "each", " ", "of", " ", "the",
      " ", "m", " ", "harmonic", " ", "minimum", " ", "xi", " ", "of", " ", 
     "the", " ", "potential"}]}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.982136958686914*^9, 3.982136976691943*^9}, {
   3.982138025643659*^9, 3.982138104572534*^9}, {3.9821385402517223`*^9, 
   3.98213864438233*^9}, {3.982139101148288*^9, 3.982139132880704*^9}, {
   3.982139263344142*^9, 3.9821392989877043`*^9}, {3.982144861184031*^9, 
   3.9821449026448793`*^9}, {3.9821449426997433`*^9, 3.982144943187337*^9}, {
   3.982144982286745*^9, 3.9821450319862547`*^9}, {3.9821450677582293`*^9, 
   3.9821451208259974`*^9}, {3.982145913840036*^9, 3.982145915372786*^9}, {
   3.982146758887602*^9, 3.98214676979207*^9}, {3.982146846781798*^9, 
   3.982146890747817*^9}, {3.982146925714089*^9, 3.982146940928371*^9}, {
   3.982146976348363*^9, 3.9821470076332607`*^9}, {3.982147157916973*^9, 
   3.982147204615559*^9}, 3.982147368144944*^9, 3.982149009644464*^9, {
   3.985257814645793*^9, 
   3.985258002935849*^9}},ExpressionUUID->"1899e139-c5cf-4556-86c8-\
199c6f89c58b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RSPT", "[", 
   RowBox[{"\[Mu]0_", ",", "\[Mu]1_", ",", "s_", ",", "l_", ",", "M_"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "mu0", ",", "mu1", ",", "tilt", ",", "x0", ",", "funcs", ",", "func", 
      ",", "pt"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"mu0", "=", "\[Mu]0"}], ";", "\[IndentingNewLine]", 
     RowBox[{"mu1", "=", "\[Mu]1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"tilt", "=", "s"}], ";", "\[IndentingNewLine]", 
     RowBox[{"x0", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Mod", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"HarmonicMinima", "[", 
            RowBox[{"\[Mu]0", ",", "\[Mu]1", ",", "4"}], "]"}], "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"1", ";;"}], ",", "1"}], "]"}], "]"}], ",", 
          RowBox[{"2", "\[Pi]"}]}], "]"}], "//", 
        RowBox[{
         RowBox[{"N", "[", 
          RowBox[{"#", ",", "1000"}], "]"}], "&"}]}], "//", 
       "DeleteDuplicates"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"funcs", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Normal", "@", 
          RowBox[{"Series", "[", 
           RowBox[{
            RowBox[{
             SuperscriptBox[
              RowBox[{"Cos", "[", "x", "]"}], "2"], "+", 
             FractionBox[
              RowBox[{"mu0", "+", 
               RowBox[{"mu1", " ", 
                RowBox[{"Sin", "[", "x", "]"}]}]}], 
              SuperscriptBox[
               RowBox[{"Cos", "[", "x", "]"}], "2"]]}], ",", 
            RowBox[{"{", 
             RowBox[{"x", ",", "xi", ",", 
              RowBox[{
               RowBox[{"2", "M"}], "+", "1"}]}], "}"}]}], "]"}]}], "/.", 
         RowBox[{"x", "->", 
          RowBox[{"x", "+", "xi"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"xi", ",", "x0"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"pt", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"BenderWu", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"func", ",", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "tilt", " ", 
             SqrtBox["2"], " ", 
             RowBox[{"Sin", "[", 
              RowBox[{"x", "-", 
               RowBox[{"x0", "[", 
                RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}]}], "}"}], ",", "x", 
          ",", "l", ",", "M", ",", 
          RowBox[{"Output", "\[Rule]", "\"\<Energy\>\""}], ",", 
          RowBox[{"Monitor", "->", "False"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"func", ",", "funcs"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"x0", "[", 
          RowBox[{"[", "i", "]"}], "]"}], ",", 
         RowBox[{"pt", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"Length", "[", "x0", "]"}]}], "}"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.982147700263176*^9, 3.9821478581295767`*^9}, {
   3.982149013144318*^9, 3.982149018446042*^9}, {3.982407715199247*^9, 
   3.982407715899063*^9}, 3.982412428449503*^9},
 CellLabel->"In[6]:=",ExpressionUUID->"0c543c66-fb08-4f45-b138-9e5c0b63fa3e"],

