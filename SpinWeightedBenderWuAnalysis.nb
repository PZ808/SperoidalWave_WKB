Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "define", " ", "a", " ", "function", " ", "that", " ", "finds", " ", 
     "harmonic", " ", "minima", " ", "give", " ", "the", " ", "parameters", 
     " ", "\[Mu]0"}], ",", 
    RowBox[{"\[Mu]1", " ", "of", " ", "the", " ", 
     RowBox[{"potential", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "M", " ", "determines", " ", "the", " ", "number", " ", "of", " ", 
    "minima"}], "  ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "E"}], "}"}], " ", "outputs", " ", "the", " ", "x", 
    " ", "coord", " ", "of", " ", "the", " ", "minima", " ", "and", " ", 
    "the", " ", "energy", " ", "E", " ", "it", " ", "corresponds", " ", 
    "to"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"HarmonicMinima", "[", 
    RowBox[{"\[Mu]0_", ",", "\[Mu]1_", ",", "M_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"rs", ",", "test", ",", "ddV"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"rs", "=", 
       RowBox[{"roots", "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"m1", "->", "\[Mu]1"}], ",", 
          RowBox[{"m0", "->", "\[Mu]0"}]}], "}"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"rs", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"rs", "/.", 
               RowBox[{
                RowBox[{"C", "[", "1", "]"}], "->", "n"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"n", ",", 
                RowBox[{"-", "M"}], ",", "M"}], "}"}]}], "]"}], "]"}], ",", 
           "2000"}], "]"}], "//", 
         RowBox[{
          RowBox[{"DeleteCases", "[", 
           RowBox[{"#", ",", "_Complex"}], "]"}], "&"}]}], "//", 
        "DeleteDuplicates"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"rs", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"#", ",", 
           RowBox[{"Limit", "[", 
            RowBox[{
             RowBox[{
              SuperscriptBox[
               RowBox[{"Cos", "[", "x", "]"}], "2"], "+", 
              FractionBox[
               RowBox[{"\[Mu]0", "+", 
                RowBox[{"\[Mu]1", " ", 
                 RowBox[{"Sin", "[", "x", "]"}]}]}], 
               SuperscriptBox[
                RowBox[{"Cos", "[", "x", "]"}], "2"]]}], ",", 
             RowBox[{"x", "->", "#"}]}], "]"}]}], "}"}], "&"}], "/@", 
        RowBox[{"(", "rs", ")"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"ddV", "=", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{
          SuperscriptBox[
           RowBox[{"Cos", "[", "x", "]"}], "2"], "+", 
          FractionBox[
           RowBox[{"\[Mu]0", "+", 
            RowBox[{"\[Mu]1", " ", 
             RowBox[{"Sin", "[", "x", "]"}]}]}], 
           SuperscriptBox[
            RowBox[{"Cos", "[", "x", "]"}], "2"]]}], ",", "x", ",", "x"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"test", "=", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Limit", "[", 
            RowBox[{"ddV", ",", 
             RowBox[{"x", "->", 
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}]}], "]"}], ">", "0"}], ",", 
          "True", ",", "False"}], "]"}], "&"}]}], ";", "\[IndentingNewLine]", 
      
      RowBox[{"rs", "=", 
       RowBox[{"Select", "[", 
        RowBox[{"rs", ",", "test"}], "]"}]}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
 InitializationCell->True,
