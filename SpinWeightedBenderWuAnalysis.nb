             RowBox[{"m1", " ", 
              RowBox[{"Sin", "[", "x", "]"}]}]}], 
            SuperscriptBox[
             RowBox[{"Cos", "[", "x", "]"}], "2"]]}], ",", "x"}], "]"}], "==",
         "0"}], ",", "x"}], "]"}]}], "//", "FullSimplify"}]}], ";"}]], "Input",\

